entity = {
	name = "fex_tainted_gaia_entity"
	pdxmesh = "planet_clouded_mesh"

	#planet surface texture override
	meshsettings = {
	name = "planet_geosphereShape"
	texture_diffuse = "fex_tainted_gaia_diffuse.dds"
	texture_normal = "tropical_03_normal.dds"
	texture_specular = "fex_tainted_gaia_spec.dds"
	}

	##cloud texture override
	meshsettings = {
	name = "clouds_geosphereShape"
	texture_diffuse = "clouds_medium_diffuse.dds"
	texture_normal = "clouds_medium_normal.dds"
	texture_specular = "clouds_medium_specular.dds"
	}

	##cloud shadow texture override
	meshsettings = {
	name = "clouds_shadow_geosphereShape"
	texture_diffuse = "clouds_medium_shadow_diffuse.dds"
	texture_normal = "nonormal.dds"
	texture_specular = "nospec.dds"
	}

	default_state = "idle"
	state = { name = "idle" animation = "idle" time_offset = { 0 100 }
		start_event = { trigger_once = yes sound = { soundeffect = "amb_planet_class" } }
		start_event = { trigger_once = yes sound = { soundeffect = "amb_planet_class_02" } }
	}
}

entity = {
	name = "fex_desert_relic_entity"
	pdxmesh = "planet_clouded_mesh"

	meshsettings = {
		name = "planet_geosphereShape"
		texture_diffuse = 	"fex_desert_relic_diffuse.dds"
		texture_normal = 	"fex_desert_relic_normal.dds"
		texture_specular = 	"fex_desert_relic_specular.dds"
	}

	default_state = "idle"
	state = { name = "idle" animation = "idle" time_offset = { 0 100 }
		start_event = { trigger_once = yes sound = { soundeffect = "amb_planet_class" } }
		start_event = { trigger_once = yes sound = { soundeffect = "amb_planet_class_02" } }
	}
}